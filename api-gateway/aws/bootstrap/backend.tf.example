# Optional remote state for the Docker agent host bootstrap stack.
# Copy to backend.tf and fill before terraform init, e.g.:
#
#   bucket = "<account-id>-subconscious-tfstate"
#   key    = "bootstrap/docker-agent-host/default/terraform.tfstate"
#   region = "us-east-2"
#
# terraform {
#   backend "s3" {
#     bucket       = "REPLACE_WITH_TF_STATE_BUCKET"
#     key          = "bootstrap/docker-agent-host/default/terraform.tfstate"
#     region       = "us-east-2"
#     encrypt      = true
#     use_lockfile = true
#   }
# }
