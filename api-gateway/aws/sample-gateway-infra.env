# Example Assisted Self-Managed infra env (AWS)
# Orange Line Labs reference: awsgateway.orangelinelabs.com
#
# Paste into the api-gateway-infra Distr Docker deployment environment.
# Day-0 host: api-gateway/aws/bootstrap (instance profile; no AWS keys in Hub).
# Full procedure: instructions.md · Secrets: gateway-secrets.md · FAQ: ../../FAQ.md
#
# Hub path (summary):
#   1. Bootstrap EC2 + connect Distr Docker agent
#   2. Create Hub Secrets: DISTR_TOKEN, DD_API_KEY, DD_APP_KEY,
#      optional awsgateway-api-gateway_GATEWAY_DASHBOARD_BOOTSTRAP_PASSWORD
#   3. Paste this file into the infra Docker deployment env
#   4. First apply may soft-skip gateway auto-deploy until the K8s agent exists
#   5. Connect Distr Kubernetes agent; target name MUST equal
#      GATEWAY_DISTR_DEPLOYMENT_NAME (namespace + Helm release)
#   6. Re-run with GATEWAY_AUTO_DEPLOY=true and GATEWAY_CHART_VERSION=latest
#
# Do not commit real secret values.
# Avoid putting curly-brace Secrets expressions in comments (Distr parses the
# whole file as a Go template).

# --- SECRETS (Hub Secrets refs) ---

DISTR_TOKEN={{.Secrets.DISTR_TOKEN}}

# Required when DATADOG_ENABLED=true
DD_API_KEY={{.Secrets.DD_API_KEY}}
DD_APP_KEY={{.Secrets.DD_APP_KEY}}

# Optional first dashboard admin (12+ chars). Create a Hub Secret and reference
# it here; the runner copies the resolved value into AWS SM app JSON (ESO sync).
# Leave empty to skip.
DASHBOARD_BOOTSTRAP_PASSWORD={{.Secrets.awsgateway-api-gateway_GATEWAY_DASHBOARD_BOOTSTRAP_PASSWORD}}

# --- PLATFORM ---

CLOUD=aws
# Infra Distr Docker deploy + TF name_prefix / EKS cluster (<= 32 chars).
DEPLOY_NAME=awsgateway-api-gateway-infra
DOMAIN_NAME=awsgateway.orangelinelabs.com
DNS_ZONE_NAME=orangelinelabs.com

AWS_REGION=us-east-2
AWS_PROJECT=api-gateway
# Optional; default is account-id-subconscious-tfstate
TF_STATE_BUCKET=

KUBERNETES_VERSION=1.31
NODE_INSTANCE_TYPES=m7g.xlarge
NODE_DESIRED_SIZE=2
NODE_MIN_SIZE=2
NODE_MAX_SIZE=4

# Dedicated VPC CIDR. Pick a /16 that does not overlap other VPCs in this
# account (needed if you later peer or share routing). Not auto-detected.
VPC_CIDR=10.60.0.0/16

# Day-0: true. Leave CLUSTER_ENDPOINT_PUBLIC_ACCESS_CIDRS empty unless you need extra CIDRs; the runner fills this host's /32.
CLUSTER_ENDPOINT_PUBLIC_ACCESS=true
CLUSTER_ENDPOINT_PUBLIC_ACCESS_CIDRS=

DATADOG_ENABLED=true
# Orange Line Labs Datadog site (US5)
DATADOG_SITE=us5.datadoghq.com
# Defaults to DEPLOY_NAME when empty - scopes dashboard title, monitors, pipeline
DATADOG_ENV=
# US5 often restricts dashboard tag keys; default team:api-gateway is enough.
# Uniqueness across deploys is the title prefix [DATADOG_ENV].
# DATADOG_DASHBOARD_TAGS=team:api-gateway
DATADOG_MONITOR_NOTIFICATION=
DATADOG_MONITORS_DRAFT=false
DATADOG_INCLUDE_ROUTER_MONITORS=true
DATADOG_INCLUDE_ADAPTER_MONITORS=true

# Gateway Distr Helm deploy = K8s namespace = Helm release (= Hub secret prefix).
GATEWAY_DISTR_DEPLOYMENT_NAME=awsgateway-api-gateway
# latest (default) | nochange | semver name like 0.15.0
GATEWAY_CHART_VERSION=latest
# false until K8s agent target GATEWAY_DISTR_DEPLOYMENT_NAME exists; then true
# (With current runner: true on first pass is OK - secrets upsert always after
# TF; auto-deploy soft-skips until the K8s target exists.)
GATEWAY_AUTO_DEPLOY=true

# Provider DNS suffixes for this deploy (required for production+adapter).
# Matches the suffix and any subdomain (e.g. l4-a.subconscious.dev).
GATEWAY_ROUTE_ALLOWED_HOST_SUFFIXES=subconscious.dev,api.baseten.co,orangelinelabs.com

# Used when DASHBOARD_BOOTSTRAP_PASSWORD is set
DASHBOARD_BOOTSTRAP_USERNAME=admin
DASHBOARD_BOOTSTRAP_ORG_NAME=Orange Line Labs
DASHBOARD_BOOTSTRAP_FULL_NAME=Gateway Admin

# Subconscious-published api-gateway Helm Application (leave as-is unless forking)
DISTR_GATEWAY_APPLICATION_ID=df563de2-25e4-4d8b-b24c-53bb4ad11086
# Rare UUID override; prefer GATEWAY_CHART_VERSION instead
DISTR_GATEWAY_APPLICATION_VERSION_ID=

# 1 = terraform plan only
DISTR_DRY_RUN=0
